# =============================================================================
# Path Pilot — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=PathPilot
APP_URL=http://localhost:5173
API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Backend (FastAPI — preferred per architecture)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=86400

# -----------------------------------------------------------------------------
# Database (Supabase / PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/pathpilot
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# External APIs (Optional — Phase 5+)
# -----------------------------------------------------------------------------
GITHUB_API_TOKEN=
YOUTUBE_API_KEY=
GOOGLE_BOOKS_API_KEY=

# -----------------------------------------------------------------------------
# Frontend (Vite — prefix with VITE_ for client access)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=PathPilot
