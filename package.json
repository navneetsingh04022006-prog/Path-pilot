{
  "name": "pathpilot",
  "private": true,
  "version": "0.1.0",
  "description": "Path Pilot — AI-powered career guidance platform",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "build:frontend": "npm run build --prefix frontend",
    "lint:frontend": "npm run lint --prefix frontend",
    "install:frontend": "npm install --prefix frontend",
    "install:backend": "pip install -r backend/requirements.txt"
  }
}
